# ClearAgent MVP — Environment Variables

# PostgreSQL
DATABASE_URL=postgresql://clearagent:clearagent@localhost:5432/clearagent

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3000
NODE_ENV=development

# JWT (required in production — generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-256-bit-secret-in-production

# API Key (for demo — in production, generate via API)
DEMO_API_KEY=ca_test_demo_key_clearagent_2026

# CORS — set these to your deployed URLs
DASHBOARD_URL=http://localhost:5173
LANDING_URL=http://localhost:3001
CORS_EXTRA_ORIGIN=

# RFC 3161 Timestamp Anchoring (Art. 12 — external timestamp authority)
RFC3161_TSA_URL=http://timestamp.digicert.com

# Dashboard
VITE_API_URL=http://localhost:3000
